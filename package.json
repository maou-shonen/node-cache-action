{
  "name": "node-cache-action",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "ncc build src/main.ts -o dist/main --source-map && ncc build src/cache-save.ts -o dist/cache-save --source-map",
    "test": "vitest run",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/node": "^25.0.3",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^6.0.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "minimatch": "~3.1.4",
    "fast-xml-parser": "^5.5.7"
  },
  "packageManager": "bun@1.3.14"
}
